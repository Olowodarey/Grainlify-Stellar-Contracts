# ==============================================================================
# Grainlify - Local Sandbox Configuration
# ==============================================================================
SOROBAN_RPC_URL="http://localhost:8000/rpc"
SOROBAN_NETWORK_PASSPHRASE="Standalone Network ; February 2017"
SOROBAN_NETWORK="local"
FRIENDBOT_URL="http://localhost:8000/friendbot"

DEPLOYER_IDENTITY="grainlify-local-deployer"

WASM_DIR="soroban/target/wasm32-unknown-unknown/release"
DEFAULT_CONTRACTS="escrow,program_escrow"

VERBOSE="true"
DEPLOYMENT_LOG="deployments/local.json"
CLI_TIMEOUT="60"
RETRY_ATTEMPTS="2"
RETRY_DELAY="2"

REQUIRE_CONFIRMATION="false"
DRY_RUN="false"
BACKUP_STATE="false"
